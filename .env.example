# KIS Open API 인증 정보 (한국투자증권)
# 이 파일은 "예시 템플릿"입니다. 실제 값은 .env 파일에 넣으세요.
# .env 파일은 .gitignore에 등록되어 있어 깃에 올라가지 않습니다.

# ─── 실거래 ──────────────────────────────────
KIS_REAL_APP_KEY=your_real_app_key_here
KIS_REAL_APP_SECRET=your_real_app_secret_here
KIS_REAL_ACCOUNT_NO=12345678-01   # 계좌번호-상품코드
KIS_REAL_BASE_URL=https://openapi.koreainvestment.com:9443

# ─── 모의투자 ────────────────────────────────
KIS_PAPER_APP_KEY=your_paper_app_key_here
KIS_PAPER_APP_SECRET=your_paper_app_secret_here
KIS_PAPER_ACCOUNT_NO=50123456-01
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443

# ─── 환경 토글 ───────────────────────────────
# "paper" = 모의투자 / "real" = 실거래
# 처음부터 한동안은 무조건 "paper" 유지
KIS_ENV=paper

# ─── Telegram 알림 ──────────────────────────
# 1. Telegram에서 @BotFather 에게 /newbot 명령 → 봇 생성 → 토큰 받기
# 2. 만든 봇에게 아무 메시지나 보낸 뒤:
#    curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[].message.chat.id'
#    → 숫자 chat_id 출력됨
# 3. 두 값을 여기에 입력 (비워두면 알림 비활성)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Slack 알림 (6개 채널 분리) ────────────────
# Slack workspace → Apps → "Incoming Webhooks" 기본 앱 설치
# 채널마다 webhook URL 별도 생성 → 각각 입력
#
# 채널 구조:
#   국장 실시간 거래공유  ← VAA 매매 알림
#   국장 일일 마감 보고서 ← daily_snapshot (15:45 KST)
#   국장 주간 종합 보고서 ← weekly_report (일요일 21:00)
#   미장 실시간 거래공유  ← Faber/NVDA v3/Catalyst 매매 알림
#   미장 일일 마감 보고서 ← us_closing_report (Tue~Sat 06:15)
#   미장 주간 종합 보고서 ← weekly_report (일요일 21:00)
#
# 비워두면 SLACK_WEBHOOK_URL (default) 로 fallback. 둘 다 비우면 Slack 비활성.
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_KR_REALTIME=
SLACK_WEBHOOK_KR_DAILY=
SLACK_WEBHOOK_KR_WEEKLY=
SLACK_WEBHOOK_US_REALTIME=
SLACK_WEBHOOK_US_DAILY=
SLACK_WEBHOOK_US_WEEKLY=

# 시스템 에러 전용 (KIS API 실패, 매매 reject, 토큰 만료 등)
# 비워두면 default URL 로 fallback. 별도 채널 권장 (사고 즉시 인지)
SLACK_WEBHOOK_SYSTEM_ERROR=
